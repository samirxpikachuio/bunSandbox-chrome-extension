{
  "manifest_version": 3,
  "name": "Bun & Node.js Sandbox",
  "version": "1.3",
  "description": "Run Bun and Node.js code autonomously via WebContainers or local server.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:3006/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
     
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  }
}
