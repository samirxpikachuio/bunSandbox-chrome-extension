{
  "manifest_version": 3,
  "name": "Sandbox 🚀",
  "version": "2.1",
  "description": "High-performance Node.js & Bun Sandbox",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:3006/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Open Sandbox"
  },
  "icons": {
    "128": "icons/icon.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
